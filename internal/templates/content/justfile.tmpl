set shell := ["/bin/sh", "-c"]

DBMATE_GENERAL_OPTIONS := "--migrations-dir ./db/migrations"

default:
  @just --list

# go vet.
[group('go')]
vet: templ tidy
  @cd backend && go vet ./... && echo "🆗 go vet was successfully executed."

# go mod tidy.
[group('go')]
tidy:
  @cd backend && go mod tidy && echo "🆗 go mod tidy was successfully executed."

# Start the dev server with air.
[group('go')]
dev: tidy {{if (eq .DB "postgres")}}db-start{{end}}
  cd backend && air

# generate templ files.
[group('go')]
templ:
  @# `go mod download` all is required to bootstrap the templ generation on the first run of the app.
  @cd backend && go mod download all
  @cd backend && go tool templ generate -path ./internal/views && echo "🆗 successfully generated views from templ files."

# remove temporary files.
clean:
  @rm -rf ./build && cd backend && rm -rf ./tmp && echo "🆗 clean was successfully executed."

# build for deployment.
[group('deployment')]
build: clean vet templ tidy
  @cd backend && env GOOS=freebsd GOARCH=amd64 go build -o ../build/{{.MainName}} ./cmd/{{.MainName}} && echo "🆗 built {{.MainName}} for FreeBSD-amd64 successfully."

# deploy.
[group('deployment')]
deploy: build
  @ssh -i ${DEPLOY_KEY} ${DEPLOY_USER}@${DEPLOY_HOST} service {{.DaemonName}} stop
  @scp -i ${DEPLOY_KEY} ./build/{{.DaemonName}} ${DEPLOY_USER}@${DEPLOY_HOST}:/usr/local/bin/{{.DaemonName}}
  @ssh -i ${DEPLOY_KEY} ${DEPLOY_USER}@${DEPLOY_HOST} service {{.DaemonName}} start
  @echo "✅ {{.DaemonName}} was successfully deployed."

# ssh into deploy server.
[group('deployment')]
ssh:
  @ssh -i ${DEPLOY_KEY} ${DEPLOY_USER}@${DEPLOY_HOST}

# create db backup.
[group('deployment')]
backup:
  @scp -i ${DEPLOY_KEY} ${DEPLOY_USER}@${DEPLOY_HOST}:/usr/local/share/{{.DaemonName}}.d/{{.DaemonName}}.sqlite3 ./backups
  @mv ./backups/{{.DaemonName}}.sqlite3 ./backups/{{.DaemonName}}-$(date -I).sqlite3

{{if (eq .DB "sqlite")}}
# open sqlite cli.
[group('sql')]
sql:
  cd db && sqlite3 database.sqlite3
{{else  if (eq .DB "postgres")}}
# open postgres client pgcli.
[group('sql')]
sql:
  pgcli -u ${DB_USER} -d ${DB_NAME}

# Start PostgreSQL service using docker-compose.
[group('sql')]
db-start:
  @docker compose up -d postgres
  @echo "🆗 PostgreSQL service is running on port 5432"

# Stop PostgreSQL service.
[group('sql')]
db-stop:
  @docker compose down
  @echo "⏹️ PostgreSQL service stopped"

# Show PostgreSQL service status.
[group('sql')]
db-status:
  @docker compose ps
{{end}}

# run database migrations.
# [group('sql')]
# migrate: 
#     dbmate {{"{{"}}DBMATE_GENERAL_OPTIONS{{"}}"}} up

# rollback the last database migration.
[group('sql')]
rollback: 
    dbmate {{"{{"}}DBMATE_GENERAL_OPTIONS{{"}}"}} rollback

# drop the db managed by dbmate.
[group('sql')]
drop:
    dbmate {{"{{"}}DBMATE_GENERAL_OPTIONS{{"}}"}} drop

# create a new migration file with name `MIGRATION_NAME`.
[group('sql')]
new MIGRATION_NAME:
  dbmate {{"{{"}}DBMATE_GENERAL_OPTIONS{{"}}"}} new {{"{{"}}MIGRATION_NAME{{"}}"}}
